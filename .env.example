# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5

# API keys (only the one matching LLM_PROVIDER is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=funnel-screenshots

# OpenClaw Alerts
OPENCLAW_PORT=18789
OPENCLAW_TOKEN=
OPENCLAW_TELEGRAM_TARGET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# Composio (tool connections — Slack, Gmail, etc.)
COMPOSIO_API_KEY=        # from composio.dev dashboard
COMPOSIO_SLACK_CHANNEL=  # e.g. #alerts (defaults to #general)
