# Apify (Meta Ads Library Scraper)
APIFY_API_TOKEN=
APIFY_ADS_ACTOR_ID=curious_coder/facebook-ads-library-scraper
AD_SCRAPE_HOUR_UTC=6

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
