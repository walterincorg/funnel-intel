# LLM provider: anthropic | openai | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5

# Browser mode
# Set to "false" on VPS to run headed Chrome (required for sites that block headless).
# When BROWSER_HEADLESS=false you must also set DISPLAY to a running Xvfb server.
BROWSER_HEADLESS=true
# Required when BROWSER_HEADLESS=false — point at the Xvfb display.
# On the VPS Xvfb runs on :99 (see CONFIG.md for setup).
DISPLAY=

# API keys (only the one matching LLM_PROVIDER is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=funnel-screenshots

# OpenClaw Alerts (routed via `openclaw message send` CLI)
OPENCLAW_TELEGRAM_TARGET=
# Point at the shared gateway config when the worker runs as a different
# user than the openclaw service account. Example on the VPS:
#   OPENCLAW_CONFIG_PATH=/home/openclawapp/.openclaw/openclaw.json
OPENCLAW_CONFIG_PATH=

# Apify (Meta Ads Library Scraper)
APIFY_API_TOKEN=
APIFY_ADS_ACTOR_ID=curious_coder/facebook-ads-library-scraper
AD_SCRAPE_HOUR_UTC=6
AD_SCRAPE_DAYS_OF_WEEK=0,3

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=

# Logging
# LOG_LEVEL: DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO
# LOG_FORMAT: "text" (human-readable, default) or "json" (structured, for log aggregators)
LOG_FORMAT=text
# LOG_FILE: optional path for rotating file output (e.g. /var/log/funnel-intel/app.log)
LOG_FILE=
# LOG_LEVELS: per-module overrides (comma-separated module=LEVEL pairs)
#   Example: LOG_LEVELS=backend.worker.traversal=DEBUG,backend.routers=DEBUG
LOG_LEVELS=
